{
  "name": "grrr-amsterdam/nova-pages-tool",
  "description": "A Laravel Nova Tool to manage pages.",
  "keywords": [
    "laravel",
    "nova"
  ],
  "license": "MIT",
  "require": {
    "php": "~8.2.0",
    "axn/laravel-eloquent-authorable": "dev-l11-compatibility",
    "laravel/nova": "^5.0",
    "outl1ne/nova-menu-builder": "dev-main",
    "outl1ne/nova-multiselect-field": "^5.0",
    "spatie/once": "^1.1|^2.0|^3.0",
    "whitecube/nova-flexible-content": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Grrr\\Pages\\": "src/",
      "Grrr\\Pages\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://nova.laravel.com"
    },
    {
      "type": "vcs",
      "url": "https://github.com/laravel-shift/laravel-eloquent-authorable.git"
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Grrr\\Pages\\ToolServiceProvider"
      ]
    }
  },
  "require-dev": {
    "orchestra/testbench": "~v9.0",
    "phpunit/phpunit": "^10.0"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "./vendor/bin/phpunit --colors=always",
    "format": "./node_modules/.bin/prettier --write ."
  }
}
